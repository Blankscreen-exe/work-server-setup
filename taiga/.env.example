# Taiga URLs
TAIGA_SCHEME=https
TAIGA_DOMAIN=taiga.dev-in-trenches.com
SUBPATH=""
WEBSOCKETS_SCHEME=wss

# Secret Key - CHANGE THIS to a random value: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key

# Database
POSTGRES_USER=taiga
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Email (use "console" to just log emails, "smtp" for real email)
EMAIL_BACKEND=console
EMAIL_HOST=smtp.host.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=user
EMAIL_HOST_PASSWORD=password
EMAIL_DEFAULT_FROM=changeme@example.com
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# RabbitMQ
RABBITMQ_USER=taiga
RABBITMQ_PASS=change-me-rabbitmq-password
RABBITMQ_VHOST=taiga
RABBITMQ_ERLANG_COOKIE=change-me-erlang-cookie

# Attachments
ATTACHMENTS_MAX_AGE=360

# Telemetry
ENABLE_TELEMETRY=False
