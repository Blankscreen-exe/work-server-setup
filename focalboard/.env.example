# Focalboard Database Configuration
FOCALBOARD_DB_TYPE=postgres
FOCALBOARD_DB_CONFIG=postgres://focalboard:change_this_password@focalboard-db:5432/focalboard?sslmode=disable

# PostgreSQL Database Configuration (for focalboard-db service)
POSTGRES_USER=focalboard
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=focalboard
