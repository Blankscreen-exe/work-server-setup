# Kanboard Application Configuration
APPLICATION_URL=http://YOUR_SERVER_IP/kanboard
URL_BASE=http://YOUR_SERVER_IP/kanboard

# MySQL Database Configuration (for kanboard-db service)
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=kanboard
MYSQL_USER=kanboard
MYSQL_PASSWORD=change_this_password

# Database URL (constructed from above values)
DATABASE_URL=mysql://kanboard:change_this_password@kanboard-db/kanboard
